# ─── Git / CI ────────────────────────────────────────────────
.git/
.github/
.gitignore

# ─── Python cache ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ─── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/

# ─── Trained model (rebuilt at Docker build time) ────────────
*.pkl
*.pickle

# ─── IDE / Editor ────────────────────────────────────────────
.idea/
.vscode/

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────
*.log
*.tmp
