# ═══════════════════════════════════════════════════════════
#  Smart Campus Carbon Tracker — .gitignore
#  Covers: Java/Maven · Node/React · Python/Flask · Docker · IDE · OS
# ═══════════════════════════════════════════════════════════

# ─── Java / Maven ───────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
hs_err_pid*
.mvn/wrapper/maven-wrapper.jar

# ─── Node.js / React ────────────────────────────────────────
node_modules/
dist/
build/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment & Secrets ──────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
carbon-frontend/.env*

# ─── Python / Flask / ML ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.Python
venv/
.venv/
env/
ENV/
*.pkl
*.pickle
carbon-ml/dataset.csv

# ─── IDE / Editor ───────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.project
.classpath
.settings/
.vscode/
*.swp
*.swo

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/

# ─── Logs & Temp ────────────────────────────────────────────
*.log
logs/
logs.txt
full_logs.txt
*.tmp
*.temp
*.bak

# ─── Sensitive / Dev-only SQL ───────────────────────────────
reset_password.sql

# ─── Hash / Build info files ────────────────────────────────
hash.txt
final_hash.txt

# ─── Docker local volumes ───────────────────────────────────
.docker/

# ─── GitHub Actions runner (self-hosted) ────────────────────
_work/
.runner
.credentials
